<% layout('/layouts/boilerplate') -%>

<style>
  .filters-wrapper {
    display: flex;
    align-items: center;
  }

  #filters {
    display: flex;
    overflow-x: auto;
    flex: 1;
    gap: 1rem;
    scrollbar-width: none;
  }

  #filters::-webkit-scrollbar {
    display: none;
  }

  .filter {
    flex: 0 0 auto;
    text-align: center;
    color: rgb(138, 138, 138);
    margin-right: 1rem;
    margin-top: 1rem;
    height: 5rem;
    width: 5rem;
    position: relative;
    cursor: pointer;
    text-decoration: none;
  }

  .filter:hover {
    color: rgb(52, 51, 51);
  }

  .filter::after {
    content: "";
    position: absolute;
    width: 0;
    border-radius: 20px;
    height: 3px;
    background: rgb(52, 51, 51);
    left: 50%;
    bottom: 5px;
    transform: translateX(-50%);
    transition: 0.3s;
  }

  .filter:hover::after,
  .filter.active::after {
    width: 5rem;
  }

  .filter.active {
    color: rgb(52, 51, 51);
    font-weight: 600;
  }

  .tax-toggle {
    height: 3rem;
    color: grey;
    padding: 10px;
    flex: 0 0 auto;
    border-radius: 15px;
    border: 2px solid grey;
    margin-left: 1rem;
  }

  .tax-info {
    display: none;
  }

  .no-results {
    text-align: center;
    margin-top: 3rem;
    color: grey;
  }
</style>

<body>
  <div class="filters-wrapper">
    <div id="filters">

      <%
        const filters = [
          { key: "all",      icon: "fa-solid fa-grip",           label: "All"      },
          { key: "trending", icon: "fa-solid fa-fire",           label: "Trending" },
          { key: "rooms",    icon: "fa-solid fa-bed",            label: "Rooms"    },
          { key: "mountains",icon: "fa-solid fa-mountain",       label: "Mountains"},
          { key: "lake",     icon: "fa-solid fa-water",          label: "Lake"     },
          { key: "beach",    icon: "fa-solid fa-umbrella-beach", label: "Beach"    },
          { key: "forest",   icon: "fa-solid fa-tree",           label: "Forest"   },
          { key: "arctic",   icon: "fa-solid fa-snowflake",      label: "Arctic"   },
          { key: "camping",  icon: "fa-solid fa-campground",     label: "Camping"  },
          { key: "city",     icon: "fa-solid fa-building",       label: "City"     },
          { key: "castles",  icon: "fa-solid fa-chess-rook",     label: "Castles"  },
          { key: "pools",    icon: "fa-solid fa-water-ladder",   label: "Pools"    },
        ];
      %>

      <% for(let f of filters) { %>
        <a
          href="/listings?category=<%= f.key %><%= search ? '&search=' + encodeURIComponent(search) : '' %>"
          class="filter <%= category === f.key ? 'active' : '' %>"
        >
          <div><i class="<%= f.icon %>"></i></div>
          <p><%= f.label %></p>
        </a>
      <% } %>

    </div>

    <div class="tax-toggle">
      <div class="form-check-reverse form-switch" style="margin-top: 2px;">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
        <label class="form-check-label" for="switchCheckDefault">
          <b>Display total after taxes</b>
        </label>
      </div>
    </div>
  </div>

  <% if(search) { %>
    <p class="mt-3 text-muted">
      Search results for: <b>"<%= search %>"</b>
      — <a href="/listings?category=<%= category %>">Clear search</a>
    </p>
  <% } %>

  <% if(allListings.length === 0) { %>
    <div class="no-results">
      <h4>No listings found</h4>
      <p>Try a different search or filter.</p>
      <a href="/listings" class="btn btn-outline-danger mt-2">Clear all filters</a>
    </div>
  <% } else { %>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-2" id="sec">
      <% for(let listing of allListings) { %>
        <a style="text-decoration: none;" href="/listings/<%= listing._id %>">
          <div class="card col">
            <img src="<%= listing.image.url %>" class="card-img-top" alt="listings_image">
            <div class="card-body">
              <p class="card-text">
                <b><%= listing.title %></b><br>
                <%= listing.location %>, <%= listing.country %><br>
                &#8377;<%= listing.price.toLocaleString("en-IN") %>/night
                <i class="tax-info">&nbsp;&nbsp;<b>+18% GST</b></i>
              </p>
              <p>
                <i class="tax-info">Price after tax: &#8377;<%= (listing.price * 1.18).toLocaleString("en-IN") %>/night</i>
              </p>
            </div>
          </div>
        </a>
      <% } %>
    </div>
  <% } %>
</body>

<script>
  let taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener('click', () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for (let info of taxInfo) {
      info.style.display = info.style.display !== "inline" ? "inline" : "none";
    }
  });
</script>
