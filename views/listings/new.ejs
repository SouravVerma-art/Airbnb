<% layout('/layouts/boilerplate') -%>

<div class="create-wrapper">
  <div class="create-card">
    <h2 class="create-title mb-4">Create a New Listing</h2>

    <form method="POST"
          action="/listings"
          class="needs-validation create-form"
          novalidate
          enctype="multipart/form-data">

      <!-- Title -->
      <div class="mb-3">
        <label class="form-label">Title</label>
        <input
          type="text"
          name="listing[title]"
          class="form-control"
          placeholder="Enter title"
          required>
        <div class="invalid-feedback">
          A listing title is required.
        </div>
        <div class="valid-feedback">
          Great! This title will attract potential guests.
        </div>
      </div>

      <!-- Description -->
      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea
          name="listing[description]"
          class="form-control"
          placeholder="Enter description"
          rows="3"
          required></textarea>
        <div class="invalid-feedback">
          Please provide a short description of the property.
        </div>
        <div class="valid-feedback">
          Nice description, it clearly explains the property.
        </div>
      </div>

      <!-- Image URL -->
      <div class="mb-3">
        <label class="form-label">Upload Listing Image</label>
        <input
          type="file"
          name="listing[image][url]"
          class="form-control"
          required>
          required
        <div class="invalid-feedback">
          A valid image URL is required.
        </div>
        <div class="valid-feedback">
          Perfect! The image link has been added successfully.
        </div>
      </div>

      <!-- Price & Country Row -->
      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="form-label">Price (₹)</label>
          <input
            type="number"
            name="listing[price]"
            class="form-control"
            placeholder="Enter price"
            required>
          <div class="invalid-feedback">
            Please enter a price for the listing.
          </div>
          <div class="valid-feedback">
            Good pricing, guests can now see the cost clearly.
          </div>
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label">Country</label>
          <input
            type="text"
            name="listing[country]"
            class="form-control"
            placeholder="Enter country"
            required>
          <div class="invalid-feedback">
            Country information is required.
          </div>
          <div class="valid-feedback">
            Location country recorded successfully.
          </div>
        </div>
      </div>

      <!-- Location -->
      <div class="mb-3">
        <label class="form-label">Location</label>
        <input
          type="text"
          name="listing[location]"
          class="form-control"
          placeholder="Enter location"
          required>
        <div class="invalid-feedback">
          Please specify the property location.
        </div>
        <div class="valid-feedback">
          Excellent! guests will know exactly where it is.
        </div>
      </div>

      <!-- Category -->
      <div class="mb-3">
        <label class="form-label">Category</label>
        <select name="listing[category]" class="form-select" required>
          <option value="">Select a category</option>
          <option value="trending">🔥 Trending</option>
          <option value="rooms">🛏️ Rooms</option>
          <option value="mountains">⛰️ Mountains</option>
          <option value="lake">🏞️ Lake</option>
          <option value="beach">🏖️ Beach</option>
          <option value="forest">🌲 Forest</option>
          <option value="arctic">❄️ Arctic</option>
          <option value="camping">⛺ Camping</option>
          <option value="city">🏙️ City</option>
          <option value="castles">🏰 Castles</option>
          <option value="pools">🏊 Pools</option>
        </select>
        <div class="invalid-feedback">Please select a category.</div>
      </div>

      <!-- Submit Button -->
      <button class="btn-submit" type="submit">
        Add Listing
      </button>

    </form>
  </div>
</div>